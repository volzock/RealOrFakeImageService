# ============================================
# PostgreSQL
# ============================================
POSTGRES_DB=realorfake
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5444

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Application
# ============================================
APP_PORT=8080
MODEL_NAME=real_or_fake_v1

# ============================================
# ONNX Model Paths (на хост-машине)
# ============================================
# Укажите абсолютные или относительные пути к файлам модели
MODEL_ONNX_PATH=./models/model.onnx
MODEL_DATA_PATH=./models/model.onnx.data